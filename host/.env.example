# al80-host config — copy to host/.env and fill in. host/.env is gitignored.
#
# ORDER MATTERS: run `node spotify-auth.mjs <client-id>` FIRST. It writes host/.env
# with the two SPOTIFY_ lines below (overwriting the file), then add the rest by hand.

# ── Spotify (required for the live now-playing panel) ────────────────────────
# spotify-auth.mjs writes both of these for you. Client id is from
# https://developer.spotify.com/dashboard. Without them, now-playing is skipped
# (weather + clock still rotate; --mock-device needs nothing at all).
SPOTIFY_CLIENT_ID=
SPOTIFY_REFRESH_TOKEN=

# ── Weather (optional — defaults to Detroit, works with no key) ──────────────
# Open-Meteo, no API key. lat/lon come straight from here; there's no place-name
# lookup yet. LABEL is the text drawn on the card. UNITS is F or C.
WEATHER_LAT=42.33
WEATHER_LON=-83.05
WEATHER_UNITS=F
WEATHER_LABEL=DETROIT

# ── Cycle tuning (all optional — these are the defaults) ─────────────────────
# Uncomment to change. Which panels rotate, in order:
#CYCLE_PANELS=nowplaying,weather,clock
# smart = drop-idle / focus-on-track-change / hold-on-clock. roundrobin = fixed.
#CYCLE_MODE=smart
# Per-panel dwell (ms). Floor is 8000. now-playing gets its own longer default.
#CYCLE_DWELL_MS=15000
#CYCLE_DWELL_NOWPLAYING=30000
# Jump to now-playing the moment the track changes (1 on, 0 off).
#CYCLE_NP_FOCUS_ON_CHANGE=1
# Stop showing weather once the reading is this old (ms). Default 40 min.
#CYCLE_WEATHER_STALE_MS=2400000
# FSM tick interval (ms).
#CYCLE_TICK_MS=500
# Tint the RGB to the on-screen panel's accent color (1 on). Off by default.
#CYCLE_SYNC_RGB=0
# Local alert-intake port (POST here to preempt with an alert card).
#CYCLE_ALERT_PORT=7333
